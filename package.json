{
  "name": "video-miniapp",
  "version": "3.0.0",
  "description": "Premium Video Downloader — Telegram Bot + Web Mini App",
  "main": "server.js",
  "scripts": {
    "start": "node server.js & sleep 2 && node bot.js",
