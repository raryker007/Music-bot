  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "node-telegram-bot-api": "^0.67.0",
    "uuid": "^9.0.1",
    "yt-dlp-wrap": "^2.3.12"
  },
  "engines": {
    "node": ">=18.0.0"
  },
